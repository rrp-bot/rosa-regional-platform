{
  "title": "DynamoDB Authz",
  "uid": "dynamodb-authz",
  "description": "DynamoDB authorization table metrics. Covers throttling, errors, capacity consumption, and latency for the authz tables.",
  "tags": ["aws", "cloudwatch", "dynamodb", "authz", "sre"],
  "timezone": "browser",
  "refresh": "1m",
  "schemaVersion": 38,
  "graphTooltip": 1,
  "time": { "from": "now-3h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "label": "Datasource",
        "query": "prometheus",
        "current": { "text": "Thanos", "value": "Thanos" },
        "hide": 0,
        "refresh": 1
      },
      {
        "name": "table",
        "type": "query",
        "label": "Table",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(aws_dynamodb_consumed_read_capacity_units_sum, dimension_TableName)",
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "current": { "text": "All", "value": "$__all" },
        "sort": 1
      }
    ]
  },
  "panels": [

    {
      "id": 1,
      "type": "row",
      "title": "Health – Throttles & Errors",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 }
    },

    {
      "id": 2,
      "type": "stat",
      "title": "Throttled Requests (all tables)",
      "description": "Total throttled requests across all authz tables. Should always be 0 with on-demand billing. Non-zero means DynamoDB is rejecting requests.",
      "gridPos": { "x": 0, "y": 1, "w": 8, "h": 5 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(aws_dynamodb_throttled_requests_sum{dimension_TableName=~\"$table\"}) or vector(0)",
          "legendFormat": "Throttled"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "value": null, "color": "green" }, { "value": 1, "color": "red" }]
          }
        }
      }
    },

    {
      "id": 3,
      "type": "stat",
      "title": "System Errors (all tables)",
      "description": "Internal server errors from DynamoDB. These are AWS-side failures — not your application's fault, but they affect availability.",
      "gridPos": { "x": 8, "y": 1, "w": 8, "h": 5 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(aws_dynamodb_system_errors_sum{dimension_TableName=~\"$table\"}) or vector(0)",
          "legendFormat": "System Errors"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "value": null, "color": "green" }, { "value": 1, "color": "red" }]
          }
        }
      }
    },

    {
      "id": 4,
      "type": "stat",
      "title": "User Errors (all tables)",
      "description": "Client-side errors (e.g. ConditionalCheckFailed, ValidationException). Some are expected in normal operation.",
      "gridPos": { "x": 16, "y": 1, "w": 8, "h": 5 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(aws_dynamodb_user_errors_sum{dimension_TableName=~\"$table\"}) or vector(0)",
          "legendFormat": "User Errors"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "value": null, "color": "green" }, { "value": 10, "color": "yellow" }, { "value": 100, "color": "red" }]
          }
        }
      }
    },

    {
      "id": 5,
      "type": "timeseries",
      "title": "Throttled Requests by Table",
      "gridPos": { "x": 0, "y": 6, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "aws_dynamodb_throttled_requests_sum{dimension_TableName=~\"$table\"}",
          "legendFormat": "{{ dimension_TableName }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "value": null, "color": "green" }, { "value": 1, "color": "red" }] }
        }
      },
      "options": { "tooltip": { "mode": "multi", "sort": "desc" } }
    },

    {
      "id": 6,
      "type": "timeseries",
      "title": "System Errors + User Errors by Table",
      "gridPos": { "x": 12, "y": 6, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "aws_dynamodb_system_errors_sum{dimension_TableName=~\"$table\"}",
          "legendFormat": "{{ dimension_TableName }} system"
        },
        {
          "refId": "B",
          "expr": "aws_dynamodb_user_errors_sum{dimension_TableName=~\"$table\"}",
          "legendFormat": "{{ dimension_TableName }} user"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "none" } },
      "options": { "tooltip": { "mode": "multi", "sort": "desc" } }
    },

    {
      "id": 7,
      "type": "row",
      "title": "Capacity Consumption",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 14, "w": 24, "h": 1 }
    },

    {
      "id": 8,
      "type": "timeseries",
      "title": "Consumed Read Capacity Units by Table",
      "description": "On-demand tables auto-scale, but sudden spikes can indicate unexpected load patterns or table scan queries.",
      "gridPos": { "x": 0, "y": 15, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "aws_dynamodb_consumed_read_capacity_units_sum{dimension_TableName=~\"$table\"}",
          "legendFormat": "{{ dimension_TableName }}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "none" } },
      "options": { "tooltip": { "mode": "multi", "sort": "desc" } }
    },

    {
      "id": 9,
      "type": "timeseries",
      "title": "Consumed Write Capacity Units by Table",
      "gridPos": { "x": 12, "y": 15, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "aws_dynamodb_consumed_write_capacity_units_sum{dimension_TableName=~\"$table\"}",
          "legendFormat": "{{ dimension_TableName }}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "none" } },
      "options": { "tooltip": { "mode": "multi", "sort": "desc" } }
    },

    {
      "id": 10,
      "type": "row",
      "title": "Latency",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 23, "w": 24, "h": 1 }
    },

    {
      "id": 13,
      "type": "stat",
      "title": "Avg Latency (worst table)",
      "description": "Highest average latency across all selected tables. Healthy DynamoDB is single-digit ms. Double-digit warrants investigation.",
      "gridPos": { "x": 0, "y": 24, "w": 8, "h": 5 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "max(aws_dynamodb_successful_request_latency_average{dimension_TableName=~\"$table\"})",
          "legendFormat": "Avg"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "value": null, "color": "green" }, { "value": 10, "color": "yellow" }, { "value": 50, "color": "red" }]
          }
        }
      }
    },

    {
      "id": 14,
      "type": "stat",
      "title": "p99 Latency (worst table)",
      "description": "Highest p99 latency across all selected tables. Sustained values above 25ms indicate hot partitions or large items.",
      "gridPos": { "x": 8, "y": 24, "w": 8, "h": 5 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "max(aws_dynamodb_successful_request_latency_p99{dimension_TableName=~\"$table\"})",
          "legendFormat": "p99"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "value": null, "color": "green" }, { "value": 25, "color": "yellow" }, { "value": 100, "color": "red" }]
          }
        }
      }
    },

    {
      "id": 15,
      "type": "stat",
      "title": "Tables Monitored",
      "description": "Number of DynamoDB tables currently reporting latency metrics.",
      "gridPos": { "x": 16, "y": 24, "w": 8, "h": 5 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "count(aws_dynamodb_successful_request_latency_average{dimension_TableName=~\"$table\"})",
          "legendFormat": "Tables"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "value": null, "color": "blue" }] }
        }
      }
    },

    {
      "id": 11,
      "type": "timeseries",
      "title": "Successful Request Latency (Average) by Table",
      "description": "Average latency of successful DynamoDB requests. Single-digit millisecond is healthy. Sustained double-digit ms warrants investigation.",
      "gridPos": { "x": 0, "y": 29, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "aws_dynamodb_successful_request_latency_average{dimension_TableName=~\"$table\"}",
          "legendFormat": "{{ dimension_TableName }}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" } },
      "options": { "tooltip": { "mode": "multi", "sort": "desc" } }
    },

    {
      "id": 12,
      "type": "timeseries",
      "title": "Successful Request Latency (p99) by Table",
      "description": "Tail latency. Spikes here mean a subset of requests is hitting DynamoDB hot partitions or large items.",
      "gridPos": { "x": 12, "y": 29, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "aws_dynamodb_successful_request_latency_p99{dimension_TableName=~\"$table\"}",
          "legendFormat": "{{ dimension_TableName }}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" } },
      "options": { "tooltip": { "mode": "multi", "sort": "desc" } }
    }

  ],
  "annotations": { "list": [] },
  "links": []
}
