{
  "title": "etcd Health (HCP)",
  "uid": "etcd-health-hcp",
  "description": "etcd health for Hosted Control Planes running on Management Clusters. HCP etcd runs as pods, exposing full etcd metrics (etcd_server_*, etcd_disk_*, etcd_network_*, etcd_mvcc_*). Filter by namespace to select individual HCPs.",
  "tags": ["kubernetes", "etcd", "hcp", "sre"],
  "timezone": "browser",
  "refresh": "1m",
  "schemaVersion": 38,
  "graphTooltip": 1,
  "time": { "from": "now-3h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "label": "Datasource",
        "query": "prometheus",
        "current": { "text": "Thanos", "value": "Thanos" },
        "hide": 0,
        "refresh": 1
      },
      {
        "name": "namespace",
        "type": "query",
        "label": "HCP Namespace",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(etcd_server_has_leader{namespace=~\"clusters-.*\"}, namespace)",
        "refresh": 2,
        "multi": false,
        "includeAll": true,
        "allValue": ".*",
        "sort": 1,
        "regex": ""
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Has Leader",
      "description": "Whether the etcd member has a leader. 1 = yes, 0 = no leader (cluster is unavailable for writes).",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "min(etcd_server_has_leader{namespace=~\"$namespace\"})",
          "legendFormat": "has_leader"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "1": { "text": "Yes", "color": "green" } } },
            { "type": "value", "options": { "0": { "text": "No", "color": "red" } } }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "red" },
              { "value": 1, "color": "green" }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Leader Changes (1h)",
      "description": "Number of leader elections in the last hour. Frequent changes indicate instability — network issues, disk pressure, or resource contention.",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(etcd_server_leader_changes_seen_total{namespace=~\"$namespace\"}[1h]))",
          "legendFormat": "changes"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 3, "color": "yellow" },
              { "value": 10, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "DB Size",
      "description": "Total etcd database size in bytes. Default etcd quota is 2 GiB for HCP. Approaching the quota triggers alarms and blocks writes.",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "max(etcd_mvcc_db_total_size_in_bytes{namespace=~\"$namespace\"})",
          "legendFormat": "DB size"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 1073741824, "color": "yellow" },
              { "value": 1825361101, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Proposals Failed",
      "description": "Rate of failed Raft proposals. Non-zero sustained rate indicates consensus issues — likely network partitions or insufficient quorum.",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(etcd_server_proposals_failed_total{namespace=~\"$namespace\"}[5m]))",
          "legendFormat": "failed/s"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 0.01, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Proposals Pending",
      "description": "Number of pending Raft proposals. Sustained high values indicate the leader cannot commit entries — disk I/O or network issues.",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "max(etcd_server_proposals_pending{namespace=~\"$namespace\"})",
          "legendFormat": "pending"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 5, "color": "yellow" },
              { "value": 50, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "DB Space Used %",
      "description": "Percentage of etcd DB size relative to the in-use size. A large gap between total size and in-use size means compaction + defragmentation is needed.",
      "gridPos": { "x": 20, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * max(etcd_mvcc_db_total_size_in_use_in_bytes{namespace=~\"$namespace\"}) / max(etcd_mvcc_db_total_size_in_bytes{namespace=~\"$namespace\"})",
          "legendFormat": "used %"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 50, "color": "yellow" },
              { "value": 80, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "DB Size Over Time",
      "description": "etcd database total size and in-use size. The gap between total and in-use indicates dead space reclaimable by defragmentation.",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "max by (namespace) (etcd_mvcc_db_total_size_in_bytes{namespace=~\"$namespace\"})",
          "legendFormat": "{{ namespace }} — total"
        },
        {
          "refId": "B",
          "expr": "max by (namespace) (etcd_mvcc_db_total_size_in_use_in_bytes{namespace=~\"$namespace\"})",
          "legendFormat": "{{ namespace }} — in use"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 10 }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["lastNotNull", "max"]
        }
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Raft Proposals",
      "description": "Committed vs applied vs pending vs failed Raft proposals. A growing gap between committed and applied indicates the state machine is falling behind. Pending proposals should stay near zero.",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(etcd_server_proposals_committed_total{namespace=~\"$namespace\"}[5m]))",
          "legendFormat": "committed/s"
        },
        {
          "refId": "B",
          "expr": "sum(rate(etcd_server_proposals_applied_total{namespace=~\"$namespace\"}[5m]))",
          "legendFormat": "applied/s"
        },
        {
          "refId": "C",
          "expr": "max(etcd_server_proposals_pending{namespace=~\"$namespace\"})",
          "legendFormat": "pending"
        },
        {
          "refId": "D",
          "expr": "sum(rate(etcd_server_proposals_failed_total{namespace=~\"$namespace\"}[5m]))",
          "legendFormat": "failed/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "failed/s" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } },
              { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 10] } }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["lastNotNull", "max"]
        }
      }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "WAL Fsync Duration (p99)",
      "description": "p99 write-ahead log fsync latency. This is the most critical disk I/O metric for etcd. Values above 10ms cause leader instability and election storms. HCP etcd uses EBS — monitor for volume throttling.",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.99, sum by (namespace, le) (rate(etcd_disk_wal_fsync_duration_seconds_bucket{namespace=~\"$namespace\"}[5m])))",
          "legendFormat": "{{ namespace }} — p99"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.50, sum by (namespace, le) (rate(etcd_disk_wal_fsync_duration_seconds_bucket{namespace=~\"$namespace\"}[5m])))",
          "legendFormat": "{{ namespace }} — p50"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 0.01, "color": "yellow" },
              { "value": 0.1, "color": "red" }
            ]
          },
          "custom": { "thresholdsStyle": { "mode": "dashed" } }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["lastNotNull", "max"]
        }
      }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Backend Commit Duration (p99)",
      "description": "p99 backend (boltdb) commit latency. Elevated values indicate disk pressure or large transactions. Sustained values above 25ms degrade write throughput.",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.99, sum by (namespace, le) (rate(etcd_disk_backend_commit_duration_seconds_bucket{namespace=~\"$namespace\"}[5m])))",
          "legendFormat": "{{ namespace }} — p99"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.50, sum by (namespace, le) (rate(etcd_disk_backend_commit_duration_seconds_bucket{namespace=~\"$namespace\"}[5m])))",
          "legendFormat": "{{ namespace }} — p50"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 0.025, "color": "yellow" },
              { "value": 0.1, "color": "red" }
            ]
          },
          "custom": { "thresholdsStyle": { "mode": "dashed" } }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["lastNotNull", "max"]
        }
      }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "gRPC Request Rate by Method",
      "description": "Rate of gRPC requests to etcd by method. Useful for identifying which operations (Range, Put, Txn, Compact) dominate etcd load.",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (grpc_method) (rate(grpc_server_handled_total{namespace=~\"$namespace\", grpc_service=\"etcdserverpb.KV\"}[5m]))",
          "legendFormat": "{{ grpc_method }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["lastNotNull", "max"]
        }
      }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "gRPC Error Rate",
      "description": "Rate of gRPC errors by code. Non-zero rates for codes other than OK indicate etcd-level failures (e.g., Unavailable = leader loss, ResourceExhausted = quota exceeded).",
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (grpc_code) (rate(grpc_server_handled_total{namespace=~\"$namespace\", grpc_code!=\"OK\"}[5m]))",
          "legendFormat": "{{ grpc_code }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["lastNotNull", "max"]
        }
      }
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "Network Traffic (Client)",
      "description": "Bytes sent to and received from etcd clients. Useful for sizing and detecting unexpected traffic patterns (e.g., large list operations).",
      "gridPos": { "x": 0, "y": 28, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (namespace) (rate(etcd_network_client_grpc_received_bytes_total{namespace=~\"$namespace\"}[5m]))",
          "legendFormat": "{{ namespace }} — received"
        },
        {
          "refId": "B",
          "expr": "sum by (namespace) (rate(etcd_network_client_grpc_sent_bytes_total{namespace=~\"$namespace\"}[5m]))",
          "legendFormat": "{{ namespace }} — sent"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "color": { "mode": "palette-classic" }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["lastNotNull", "max"]
        }
      }
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "Network Traffic (Peer)",
      "description": "Bytes sent to and received from etcd peers. High peer traffic indicates Raft replication load. Asymmetric traffic may indicate a slow follower.",
      "gridPos": { "x": 12, "y": 28, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (namespace) (rate(etcd_network_peer_received_bytes_total{namespace=~\"$namespace\"}[5m]))",
          "legendFormat": "{{ namespace }} — received"
        },
        {
          "refId": "B",
          "expr": "sum by (namespace) (rate(etcd_network_peer_sent_bytes_total{namespace=~\"$namespace\"}[5m]))",
          "legendFormat": "{{ namespace }} — sent"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "color": { "mode": "palette-classic" }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["lastNotNull", "max"]
        }
      }
    },
    {
      "id": 15,
      "type": "timeseries",
      "title": "Snapshot Duration",
      "description": "Time taken to create etcd snapshots. Snapshot duration correlates with DB size. Long snapshots can block writes and trigger leader elections.",
      "gridPos": { "x": 0, "y": 36, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.99, sum by (namespace, le) (rate(etcd_debugging_snap_save_total_duration_seconds_bucket{namespace=~\"$namespace\"}[5m])))",
          "legendFormat": "{{ namespace }} — p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 1, "color": "yellow" },
              { "value": 5, "color": "red" }
            ]
          },
          "custom": { "thresholdsStyle": { "mode": "dashed" } }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["lastNotNull", "max"]
        }
      }
    },
    {
      "id": 16,
      "type": "timeseries",
      "title": "Slow Apply / Slow Read Index",
      "description": "Rate of slow applies and slow read index operations. These indicate the etcd state machine or read path is under pressure. Any sustained rate is concerning.",
      "gridPos": { "x": 12, "y": 36, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (namespace) (rate(etcd_server_slow_apply_total{namespace=~\"$namespace\"}[5m]))",
          "legendFormat": "{{ namespace }} — slow apply"
        },
        {
          "refId": "B",
          "expr": "sum by (namespace) (rate(etcd_server_slow_read_indexes_total{namespace=~\"$namespace\"}[5m]))",
          "legendFormat": "{{ namespace }} — slow read index"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 0.01, "color": "red" }
            ]
          },
          "custom": { "thresholdsStyle": { "mode": "dashed" } }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["lastNotNull", "max"]
        }
      }
    }
  ]
}
