{
  "title": "etcd Health (EKS)",
  "uid": "etcd-health-eks",
  "description": "etcd health indicators available from the EKS managed control plane. Direct etcd pod metrics (etcd_server_*, etcd_disk_*, grpc_server_*, etcd_network_*) are not exposed on EKS managed control planes. This dashboard uses apiserver_storage_objects and apiserver_request_duration_seconds as the closest available proxies for etcd health.",
  "tags": ["kubernetes", "eks", "etcd", "sre"],
  "timezone": "browser",
  "refresh": "1m",
  "schemaVersion": 38,
  "graphTooltip": 1,
  "time": { "from": "now-3h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "label": "Datasource",
        "query": "prometheus",
        "current": { "text": "Thanos", "value": "Thanos" },
        "hide": 0,
        "refresh": 1
      },
      {
        "name": "cluster",
        "type": "query",
        "label": "Cluster",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(apiserver_storage_objects, cluster)",
        "refresh": 2,
        "multi": false,
        "includeAll": true,
        "allValue": ".*",
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "text",
      "title": "EKS Managed Control Plane — etcd Access Notice",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 3 },
      "options": {
        "mode": "markdown",
        "content": "**Note:** EKS manages etcd as a fully-opaque service. Metrics that require direct etcd pod access (`etcd_server_has_leader`, `etcd_server_leader_changes_seen_total`, `etcd_disk_*`, `etcd_network_*`, `grpc_server_*`, `etcd_server_proposals_*`, `etcd_debugging_snap_*`) are **not available**. This dashboard uses API server metrics as the closest available proxies for etcd health. For direct etcd metrics, use a self-managed control plane."
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Total etcd Object Count",
      "description": "Total objects stored across all etcd keys as reported by the API server (apiserver_storage_objects). A proxy for etcd database size — consistent growth without corresponding cluster activity indicates resource accumulation.",
      "gridPos": { "x": 0, "y": 3, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(apiserver_storage_objects{cluster=~\"$cluster\"})",
          "legendFormat": "Objects"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "blue" },
              { "value": 50000, "color": "yellow" },
              { "value": 100000, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "API Server Request Rate",
      "description": "Total requests/sec to the API server. High request rates directly stress etcd (every write and most reads touch etcd). Proxy for etcd client traffic load.",
      "gridPos": { "x": 6, "y": 3, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(apiserver_request_total{cluster=~\"$cluster\"}[5m]))",
          "legendFormat": "req/s"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "value": null, "color": "blue" }]
          }
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "API Server Error Rate (5xx)",
      "description": "Server-side errors as a percentage of all requests. Sustained 5xx errors can indicate etcd timeouts or write failures surfacing through the API server. Alert threshold: >1%.",
      "gridPos": { "x": 12, "y": 3, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * sum(rate(apiserver_request_total{cluster=~\"$cluster\",code=~\"5..\"}[5m])) / sum(rate(apiserver_request_total{cluster=~\"$cluster\"}[5m]))",
          "legendFormat": "5xx %"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 1, "color": "yellow" },
              { "value": 5, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "API Request Latency p99 (non-WATCH)",
      "description": "p99 API request latency excluding WATCH. Elevated latency is an early indicator of etcd read/write slowness on EKS managed control planes. SRE standard: p99 <1s for GET/LIST, <500ms for mutating verbs.",
      "gridPos": { "x": 18, "y": 3, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.99, sum by (le) (rate(apiserver_request_duration_seconds_bucket{cluster=~\"$cluster\",verb!=\"WATCH\"}[5m])))",
          "legendFormat": "p99"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 1, "color": "yellow" },
              { "value": 5, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "etcd Object Count by Resource (Top 15)",
      "description": "Number of objects per resource type stored in etcd. Equivalent to monitoring etcd key space utilisation per resource. Consistent growth in events, pods, or secrets can indicate accumulation of stale objects and etcd pressure. Replaces the upstream 'DB Size' panel (etcd_debugging_mvcc_db_total_size_in_bytes) which is not available on EKS managed control planes.",
      "gridPos": { "x": 0, "y": 7, "w": 24, "h": 9 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "topk(15, sum by (resource) (apiserver_storage_objects{cluster=~\"$cluster\"}))",
          "legendFormat": "{{ resource }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": ["lastNotNull", "max"]
        }
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "API Request Latency by Verb — p50 / p99 (etcd Proxy)",
      "description": "Latency percentiles per HTTP verb (WATCH excluded). On EKS, etcd disk sync duration (etcd_disk_wal_fsync_duration_seconds, etcd_disk_backend_commit_duration_seconds) is unavailable. Elevated GET/LIST latency is the closest observable signal for etcd read slowness; elevated PUT/DELETE/POST latency proxies etcd write / WAL fsync slowness.",
      "gridPos": { "x": 0, "y": 16, "w": 24, "h": 9 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.99, sum by (verb, le) (rate(apiserver_request_duration_seconds_bucket{cluster=~\"$cluster\",verb!=\"WATCH\"}[5m])))",
          "legendFormat": "p99 — {{ verb }}"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.50, sum by (verb, le) (rate(apiserver_request_duration_seconds_bucket{cluster=~\"$cluster\",verb!=\"WATCH\"}[5m])))",
          "legendFormat": "p50 — {{ verb }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 1, "color": "red" }
            ]
          },
          "custom": { "thresholdsStyle": { "mode": "dashed" } }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["lastNotNull", "max"]
        }
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "API Write Request Rate by Verb (etcd Write Proxy)",
      "description": "Rate of mutating verbs (POST, PUT, PATCH, DELETE). Each mutating API request results in an etcd write. Replaces upstream 'Raft Proposals' panels (etcd_server_proposals_committed_total, etcd_server_proposals_applied_total, etcd_server_proposals_pending, etcd_server_proposals_failed_total) which require direct etcd access.",
      "gridPos": { "x": 0, "y": 25, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (verb) (rate(apiserver_request_total{cluster=~\"$cluster\",verb=~\"POST|PUT|PATCH|DELETE\"}[5m]))",
          "legendFormat": "{{ verb }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["lastNotNull", "max"]
        }
      }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Watch Event Rate by Kind (etcd Network Proxy)",
      "description": "Events dispatched to active watchers per kind. High watch event rates correspond to etcd change notification volume — a proxy for etcd peer/client traffic. Replaces upstream 'Client Traffic In/Out' and 'Peer Traffic In/Out' panels which use etcd_network_* metrics unavailable on EKS.",
      "gridPos": { "x": 12, "y": 25, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (kind) (rate(apiserver_watch_events_total{cluster=~\"$cluster\"}[5m]))",
          "legendFormat": "{{ kind }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "eps",
          "color": { "mode": "palette-classic" }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["lastNotNull", "max"]
        }
      }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Dropped Requests (API Priority & Fairness)",
      "description": "Requests rejected by API priority and fairness flow control. Sustained rejections indicate the API server (and thus etcd) is saturated. Replaces upstream leader election panels — on EKS, etcd_server_leader_changes_seen_total is not accessible.",
      "gridPos": { "x": 0, "y": 33, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (flow_schema, priority_level) (rate(apiserver_flowcontrol_rejected_requests_total{cluster=~\"$cluster\"}[5m]))",
          "legendFormat": "{{ priority_level }} / {{ flow_schema }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 1, "color": "red" }
            ]
          },
          "custom": { "thresholdsStyle": { "mode": "dashed" } }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["lastNotNull", "max"]
        }
      }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "In-Flight Requests (etcd Saturation Proxy)",
      "description": "Currently active requests being processed by the API server. Sustained high values indicate API server — and by extension, etcd — saturation. Broken out by request kind (mutating vs read-only).",
      "gridPos": { "x": 12, "y": 33, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (request_kind) (apiserver_current_inflight_requests{cluster=~\"$cluster\"})",
          "legendFormat": "{{ request_kind }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 200, "color": "yellow" },
              { "value": 400, "color": "red" }
            ]
          },
          "custom": { "thresholdsStyle": { "mode": "dashed" } }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["lastNotNull", "max"]
        }
      }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Admission Webhook Latency p99",
      "description": "p99 time spent in each admission webhook. Slow webhooks add latency to every mutating request, which chains into etcd write latency. Useful for diagnosing whether elevated write latency is webhook-induced or etcd-induced.",
      "gridPos": { "x": 0, "y": 41, "w": 24, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.99, sum by (name, le) (rate(apiserver_admission_webhook_admission_duration_seconds_bucket{cluster=~\"$cluster\"}[5m])))",
          "legendFormat": "{{ name }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 0.5, "color": "yellow" },
              { "value": 1, "color": "red" }
            ]
          },
          "custom": { "thresholdsStyle": { "mode": "dashed" } }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["lastNotNull", "max"]
        }
      }
    }
  ]
}
