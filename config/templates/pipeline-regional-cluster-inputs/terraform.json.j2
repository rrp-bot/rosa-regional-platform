{
  "_generated": "DO NOT EDIT - Generated by render.py",
  "app_code": "{{ terraform_tags.app_code }}",
  "service_phase": "{{ terraform_tags.service_phase }}",
  "cost_center": "{{ terraform_tags.cost_center }}",
  "environment": "{{ environment }}",
  "account_id": "{{ account_id }}",
  "region": "{{ aws_region }}",
  "alias": "regional-{{ aws_region }}",
  "enable_bastion": {{ regional_cluster.enable_bastion | default(false) | tojson }},
  "regional_id": "{% if ci_prefix %}{{ ci_prefix }}-regional{% else %}regional{% endif %}",
  "node_instance_types": {{ regional_cluster.node_instance_types | tojson }},
  "iot_log_level": "{{ applications['regional-cluster'].maestro.iotLogLevel | default('WARN') }}"
{%- set mc_account_ids = management_clusters | selectattr("account_id", "defined") | map(attribute="account_id") | list %}
{%- if mc_account_ids %},
  "management_cluster_account_ids": {{ mc_account_ids | tojson }}{% endif %}{% if delete %},
  "delete": true{% endif %}
}
